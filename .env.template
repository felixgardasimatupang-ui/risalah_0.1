# === WAJIB DIISI ===

# HuggingFace Token (untuk Pyannote speaker diarization)
# Daftar di https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# === OPSIONAL ===

# AssemblyAI API Key (untuk cloud transcription)
# Daftar di https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Groq API Key (priority LLM untuk AI enhancement)
# Gratis daftar di https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# 9router API Key (fallback LLM, OpenAI-compatible router via headroom)
NINEROUTER_API_KEY=your_9router_api_key_here
NINEROUTER_BASE_URL=http://localhost:8787/v1
NINEROUTER_MODEL=groq/llama-3.3-70b-versatile

# === FALLBACK CHAIN AI ENHANCEMENT ===
# 1. Groq (GROQ_API_KEY) → prioritas utama
# 2. 9router (NINEROUTER_API_KEY) → fallback pertama
# 3. Gemini (GEMINI_API_KEY) → fallback terakhir

# === INFRASTRUKTUR ===

# Redis (untuk queue & job status)
# Install: brew install redis && brew services start redis
REDIS_URL=redis://localhost:6379/0

# Bahasa (id=Indonesia, en=English)
RISALAH_LANG=id

# API URL (untuk Streamlit UI)
API_URL=http://localhost:8000/api

# Headroom (context compression proxy, opsional)
# HEADROOM_ENABLED=true
# HEADROOM_URL=http://localhost:8787

# === EMAIL SHARE (OPSIONAL) ===
# SMTP config untuk fitur Share via email dari UI
# Contoh Gmail: buat App Password di https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password_here
# SMTP_FROM=your_email@gmail.com
